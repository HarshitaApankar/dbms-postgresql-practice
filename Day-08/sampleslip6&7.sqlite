/*Q2) Using above Database Solve the following [10 Marks]
Define a trigger before updating a competition table. Raise a notice and 
display message “competition record is being updated”.*/

CREATE OR REPLACE FUNCTION trigger_update()
RETURNS TRIGGER AS $$
BEGIN
	   RAISE NOTICE 'Competition record is being updated';
	   RETURN NEW;
END;
$$
LANGUAGE plpgsql;

CREATE TRIGGER trigger_competi
BEFORE UPDATE ON Competition
FOR EACH ROW
EXECUTE FUNCTION trigger_update();


UPDATE Competition
SET name = 'State Level'
WHERE c_no = 1;

/*Write a function using cursor which accepts a name of student and returns
the total no of prizes won by that student in the year 2020.*/

CREATE OR REPLACE FUNCTION cursor_student_prize(student_name VARCHAR)
RETURNS TEXT AS $$
DECLARE
      rec RECORD;
	  total_count INT:=0;
	  
	  cur CURSOR FOR
	  SELECT prize
      FROM Students, Competition, Student_Competition
      WHERE Students.s_no = Student_Competition.s_no
      AND Competition.c_no = Student_Competition.c_no
      AND s_name = stud_name
      AND year = 2020;

BEGIN
      OPEN cur;
       LOOP
	   FETCH cur INTO rec;

	   EXIT WHEN NOT FOUND;
       total_count := total_count + 1;
    END LOOP;

    CLOSE cur;

    RETURN total_count;

END;
$$
LANGUAGE plpgsql;

/*Write a procedure to accept two numbers from user and display division of two numbers
use raise to display divided by zero exception messages. [5 marks]*/

CREATE OR REPLACE PROCEDURE division_two_number(a int,b int)
LANGUAGE plpgsql AS $$
DECLARE 
     division int;
BEGIN
     IF (b=0) THEN 
	 RAISE EXCEPTION'divided by zero not possible';
     END IF ;
	 division=a/b;
	 RAISE INFO'division of % and % is: %',a,b,division;
END;	 
$$;

CALL division_two_number(10,0);
