---------------------------------------------sample slip 1----------------------------------------
-- Project Table
CREATE TABLE Project (
    pno INT PRIMARY KEY,
    pname VARCHAR(30) NOT NULL,
    ptype VARCHAR(20),
    duration INT CHECK (duration > 0)
);

-- Employee Table
CREATE TABLE Employee (
    eno INT PRIMARY KEY,
    ename VARCHAR(20),
    qualification VARCHAR(15),
    joining_date DATE
);

-- Relationship Table (Many-to-Many)
CREATE TABLE Works_On (
    eno INT,
    pno INT,
    start_date DATE,
    no_of_hours_worked INT,
    PRIMARY KEY (eno, pno),
    FOREIGN KEY (eno) REFERENCES Employee(eno),
    FOREIGN KEY (pno) REFERENCES Project(pno)
);


-- Insert into Project
INSERT INTO Project VALUES (101, 'Library System', 'Software', 6);
INSERT INTO Project VALUES (102, 'Bank App', 'Application', 8);
INSERT INTO Project VALUES (103, 'AI Chatbot', 'Research', 12);
INSERT INTO Project VALUES (105, 'Test Project', 'Demo', 0);

SELECT* FROM Project;

