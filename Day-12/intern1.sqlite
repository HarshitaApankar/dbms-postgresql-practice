----------------------SECTION A-------------------------
--1. Get all employees whose age is above 30.
SELECT * FROM employees WHERE age>30;

--2. List employee names and salaries, sorted by salary in descending order.
SELECT emp_name,salary FROM employees ORDER BY salary DESC;

--3. Find employees whose name starts with "A".
SELECT * FROM employees WHERE emp_name LIKE 'A%';

--4. Get all employees who work in department ID 3.
SELECT * FROM employees WHERE dept_id=103;

--5. List employees hired after 2022-01-01.
SELECT* FROM employees WHERE hire_date>'2022-01-01';

--6. Find employees whose salary is between 30000 and 60000.
SELECT * FROM employees WHERE salary BETWEEN 30000 AND 60000;

--7. Get distinct department IDs from the EMPLOYEE table.
SELECT DISTINCT dept_id FROM employees;

--8. List all male employees aged between 25 and 40.
SELECT * FROM employees WHERE gender='M' AND age BETWEEN 25 AND 40;

--9. Find employees whose name contains the letter "i".
SELECT *  FROM employees WHERE emp_name LIKE '%i%'

--10. Get the top 5 highest paid employees.
SELECT * FROM employees ORDER BY salary DESC LIMIT(5); 

-------------------------SECTION B----------------------------
--11. Find the total number of employees in each department.
SELECT dept_id,COUNT(*) FROM employees GROUP BY dept_id;

--12. Get the average salary of employees in each department.
SELECT dept_id,AVG(salary) AS avg_salary FROM employees GROUP BY dept_id

--13.13. Find the maximum salary in the company.
SELECT MAX(salary) AS maximum_salary FROM employees;

--14. Get the count of employees for each gender.
SELECT gender,COUNT(*) FROM employees GROUP BY gender;

--15. Find departments having more than 5 employees.
SELECT dept_id,COUNT(*) FROM employees GROUP BY dept_id HAVING COUNT(*)>3;

--16. Get the total salary expense per department.
SELECT dept_id,sum(salary) AS total_salary FROM employees GROUP BY dept_id;

--17. Find the minimum and maximum age in each department.
SELECT dept_id,MAX(age) AS max_age,MIN(age) AS min_age FROM employees GROUP BY dept_id;

--18. Get the average age of employees, grouped by department,
--only where average age > 28.
SELECT dept_id,AVG(age) AS average_age FROM employees GROUP BY dept_id HAVING AVG(age)>28;

--19. Count how many employees were hired each year.
SELECT EXTRACT(YEAR FROM hire_date) AS hire_year,COUNT(*) FROM employees GROUP BY EXTRACT(YEAR FROM hire_date);

--20. Find the department with the highest total salary expense.
SELECT dept_id,MAX(salary) as max_salary FROM employees GROUP BY dept_id ORDER BY MAX(salary) DESC LIMIT(1);

-----------------------------SECTION C JOINS----------------------
--21. List employee names along with their department names.
SELECT e.emp_name,d.dept_name FROM employees e INNER JOIN departments d ON e.dept_id=d.dept_id;

--22. Find employees who work in the "IT" department 
--(use department name, not ID).
SELECT * FROM employees WHERE dept_id IN
(SELECT dept_id FROM departments WHERE dept_name='IT')

--23. Get a list of all departments and the number of employees
--in each (include departments with zero employees).
SELECT d.dept_name, COUNT(e.emp_id) AS count_employee
FROM departments d
LEFT JOIN employees e ON e.dept_id = d.dept_id
GROUP BY d.dept_name;

--24. List project names along with the department running them.
SELECT p.project_name,d.dept_name FROM projects p
INNER JOIN departments d
ON p.dept_id=d.dept_id;

--25. Find employees who are working on a project with a budget
--greater than 500000.
SELECT e.emp_name,p.budget FROM employees e INNER JOIN projects p ON
e.dept_id=p.dept_id WHERE p.budget>500000 ORDER BY p.budget DESC;

--26. Get the names of employees and their managers (self-join).
SELECT e.emp_name AS employee_name, m.emp_name AS manager_name
FROM employee e
LEFT JOIN employee m ON e.manager_id = m.emp_id;

--27. List all departments that currently have no employees.
SELECT dept_name 
FROM departments 
WHERE dept_id IN (
    SELECT dept_id FROM employees WHERE dept_id IS NULL
);
