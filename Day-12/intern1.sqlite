CREATE TABLE salarys (
    salary_id   INT PRIMARY KEY,
    emp_id      INT,
    basic       DECIMAL(10,2),
    bonus       DECIMAL(10,2),
    deduction   DECIMAL(10,2),
    pay_month   DATE,
    FOREIGN KEY (emp_id) REFERENCES employees(emp_id)
);

