/*Section II: Database Management Systems – II

[15 Marks]

Consider the following database:

Customer
(cno integer, cname varchar(20), city varchar(20))

Account
(a_no int, a_type varchar(10), opening_date date, balance money)

Customer and Account are related with a one-to-many relationship.*/

CREATE TABLE Customer(cno int primary key,
                      cname varchar(20),
					  city varchar(20));


CREATE TABLE Account(a_no int PRIMARY KEY,
                     a_type varchar(10),
					 opening_date date,
					 balance money,
					 cno INT,
					 FOREIGN KEY(cno) REFERENCES Customer(cno));

INSERT INTO Customer VALUES
(1, 'Rahul', 'Pune'),
(2, 'Sneha', 'Mumbai'),
(3, 'Amit', 'Pune'),
(4, 'Priya', 'Delhi');

SELECT * FROM Customer;

INSERT INTO Account VALUES
(101, 'Saving', '2023-01-10', 50000, 1),
(102, 'Current', '2022-06-15', 75000, 2),
(103, 'Saving', '2023-03-20', 30000, 3),
(104, 'Fixed', '2021-12-01', 100000, 1),
(105, 'Current', '2022-08-11', 75000, 4);

SELECT * FROM Account;

/*Q2) Using above Database Solve the following

[10 Marks]

Write a function using cursor which accepts city name as input and 
prints the details of all customers in that city.*/

CREATE OR REPLACE FUNCTION print_details(city_name varchar)
RETURNS TEXT AS $$
DECLARE
       rec RECORD;
	   cur CURSOR FOR
	   SELECT * FROM Customer WHERE city=city_name;
BEGIN
     OPEN cur;
	    LOOP
	         FETCH cur INTO rec;
		     EXIT WHEN NOT FOUND;

			 RAISE NOTICE'Customer id: %,Name: %,City: %',
			 rec.cno,rec.cname,rec.city;
		END LOOP;
	  CLOSE cur;
   RETURN'Customer details displayed successfully!';
   END;
 $$
 LANGUAGE plpgsql;

 /* Write a trigger which does not allow deletion of accounts of _SAVING__ type.*/

CREATE OR REPLACE FUNCTION delete_trigger()
RETURNS TRIGGER AS $$
BEGIN
      IF OLD.a_type='Saving' THEN
	  RAISE EXCEPTION 'Account cannot be deleted';
	  END IF;

	  RETURN OLD;
END;
$$
LANGUAGE plpgsql;	 

CREATE TRIGGER check_account_delete
BEFORE DELETE ON Account
FOR EACH ROW
EXECUTE FUNCTION delete_trigger();   
					  
DELETE FROM Account WHERE a_type = 'Saving';


--Write a procedure to display all customers from ‘Pune’ city.
CREATE OR REPLACE PROCEDURE display_customer()
LANGUAGE plpgsql
AS $$
DECLARE
     rec RECORD;
BEGIN
     FOR rec IN SELECT * FROM Customer WHERE city='Pune'
	 LOOP
        RAISE NOTICE 'Customer No: %, Name: %, City: %',
                     rec.cno, rec.cname, rec.city;
    END LOOP;
END; 
$$;

CALL display_customer();

