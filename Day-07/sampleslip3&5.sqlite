/*Section II: Database Management Systems – II
Consider the following database:

Item
(itemno integer, itemname varchar(20), quantity integer)

Supplier
(supplierno integer, supplier_name varchar(20), city varchar(20))

Item and Supplier are related with a many-to-many relationship.
Rate is a descriptive attribute.*/

CREATE TABLE Item(itemno INT PRIMARY KEY,
                  itemname VARCHAR(20),
				  quantity INT);

CREATE TABLE Supplier(supplierno INT PRIMARY KEY,
                      supplier_name VARCHAR(20),
					  city VARCHAR(20));

CREATE TABLE Item_Supplier(itemno INT,
                           supplierno INT,
						   PRIMARY KEY(itemno,supplierno),
						   FOREIGN KEY(itemno)REFERENCES Item(itemno),
						   FOREIGN KEY(supplierno)REFERENCES Supplier(supplierno),
						   rate INT);

INSERT INTO Item VALUES
(1, 'Pen', 100),
(2, 'Notebook', 200),
(3, 'Pencil', 150);

INSERT INTO Supplier VALUES
(101, 'ABC Traders', 'Mumbai'),
(102, 'XYZ Suppliers', 'Pune'),
(103, 'Global Mart', 'Delhi');

INSERT INTO Item_Supplier VALUES
(1, 101, 20),
(1, 102, 25),
(2, 101, 50),
(2, 103, 55),
(3, 102, 10),
(3, 103, 12);

SELECT * FROM Item;
SELECT * FROM Supplier;
SELECT * FROM Item_Supplier;
						   
--1.Write a stored function using cursors to accept Item name 
--from the user and display the Rate and Supplier Name for that item.

CREATE OR REPLACE FUNCTION get_item_details(p_itemname VARCHAR)
RETURNS TEXT AS $$
DECLARE
    rec RECORD;

    cur CURSOR FOR
        SELECT supplier_name, rate
        FROM Item, Supplier, Item_Supplier
        WHERE Item.itemno = Item_Supplier.itemno
        AND Supplier.supplierno = Item_Supplier.supplierno
        AND itemname = p_itemname;

BEGIN
    OPEN cur;

    LOOP
        FETCH cur INTO rec;
        EXIT WHEN NOT FOUND;

        RAISE NOTICE 'Supplier Name: %, Rate: %',
                     rec.supplier_name,
                     rec.rate;
    END LOOP;

    CLOSE cur;
END;
$$ LANGUAGE plpgsql;

SELECT get_item_details('Pencil');	

/*Write a trigger before update on rate field.
If the difference between old rate and new rate is more than Rs 200,
raise an exception and display the corresponding message.*/

CREATE OR REPLACE FUNCTION trigger_update_rate()
RETURNS TRIGGER AS $$
BEGIN
   IF abs(OLD.rate-NEW.rate>200) THEN
   RAISE EXCEPTION 'Difference between old rate and new rate is more than Rs 200';
   END IF;
  RETURN NEW;
 END;
$$
LANGUAGE plpgsql;

CREATE TRIGGER rate_trigger
BEFORE UPDATE ON Item_Supplier
FOR EACH ROW
EXECUTE FUNCTION trigger_update_rate();

--procedure to accept and display addition,subtraction, multiplication and 
--division of two numbers.

CREATE OR REPLACE PROCEDURE operations(a int,b int)
LANGUAGE plpgsql AS $$
DECLARE
addi int;
sub int;
mul int;
div int;
BEGIN
addi=a+b;
raise info'addition of two numbers % and % is :%',a,b,addi;
sub=a-b;
raise info'subtraction of two numbers % and % is :%',a,b,sub;
mul=a*b;
raise info'multiplication of two numbers % and % is :%',a,b,mul;
div=a/b;
raise info'division of two numbers % and % is :%',a,b,div;
END;
$$

CALL operations(10,5)

